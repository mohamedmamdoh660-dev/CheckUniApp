    {
      "parameters": {
        "jsCode": "const messages = $input.all().map(item => ({\n  role: item.json.role,\n  content: item.json.content,\n  time: new Date(item.json.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),\n  ts: new Date(item.json.created_at).getTime()\n}));\n\n// Filter last 24 hours\nconst cutoff = Date.now() - (24 * 60 * 60 * 1000);\nconst recent = messages.filter(m => m.ts >= cutoff);\n\nreturn [{ json: { messages: recent } }];"
      },
