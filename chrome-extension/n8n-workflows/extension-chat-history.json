      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [672, 160],
      "id": "a1b2c3d4-0009-4000-8000-000000000009",
      "name": "Get All Chats",
      "credentials": {
        "supabaseApi": {
          "id": "7uIiqTJr3QPa9xmS",
          "name": "Sit Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const allMessages = $input.all().map(item => item.json);\nconst cutoff = Date.now() - (24 * 60 * 60 * 1000);\n\n// Group by session_id, filter last 24h\nconst sessionsMap = {};\nfor (const msg of allMessages) {\n  const ts = new Date(msg.created_at).getTime();\n  if (ts < cutoff) continue;\n  \n  if (!sessionsMap[msg.session_id]) {\n    sessionsMap[msg.session_id] = {\n      session_id: msg.session_id,\n      first_message: '',\n      created_at: msg.created_at,\n      message_count: 0\n    };\n  }\n  sessionsMap[msg.session_id].message_count++;\n  // Use first user message as preview\n  if (msg.role === 'user' && !sessionsMap[msg.session_id].first_message) {\n    sessionsMap[msg.session_id].first_message = msg.content.substring(0, 50);\n  }\n}\n\nconst sessions = Object.values(sessionsMap)\n  .sort((a, b) => new Date(b.created_at) - new Date(a.created_at));\n\nreturn [{ json: { sessions } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [896, 160],
