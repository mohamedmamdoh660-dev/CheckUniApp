    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://knqtjanxjwfjfrwoater.supabase.co/*",
    "https://darwish1.daxow.com/*"
  ]
}
